# ============================================================
# ChatGPT 批量注册工具 — 环境变量配置
# 复制此文件为 .env 并填写对应值
# 所有字段也可在 Web 面板的「设置」页面中修改保存
# ============================================================

# Web 面板端口（默认 5000）
PORT=5000

# Flask Session 密钥（生产环境请修改）
SECRET_KEY=changeme-please-update

# ── DuckMail 临时邮箱 ──────────────────────────────────────
# Worker API 地址，如: https://your-worker.xxxx.workers.dev/api
DUCKMAIL_API_BASE=

# 邮箱域名，如: example.com
DUCKMAIL_DOMAIN=

# Admin 密码 / Bearer Token
DUCKMAIL_BEARER=

# ── 代理（可选）────────────────────────────────────────────
# 格式: http://user:pass@host:port 或 socks5://host:port
PROXY=

# ── CPA 上传（可选）────────────────────────────────────────
UPLOAD_API_URL=
UPLOAD_API_TOKEN=

# ── SUB2API 推送（可选）────────────────────────────────────
SUB2API_URL=
SUB2API_TOKEN=
